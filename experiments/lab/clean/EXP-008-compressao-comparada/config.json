{
  "experiment_id": "EXP-008-compressao-comparada",
  "cycle": "v0.6",
  "tcf_source": "src/tcf",
  "tcf_api": ["encode", "decode"],
  "datasets_dir": "../../../../datasets/synthetic",
  "datasets": [
    "D1-emails-simples",
    "D2-emails-quote-id",
    "D3-stress-substring",
    "D4-caos-mix",
    "D5-padroes-multiplos",
    "D6-poucos-em-ruido",
    "D7-aninhamento",
    "D8-cabeca-cauda",
    "D9-frequencia-alta",
    "D10-datas-mundiais",
    "D11-datetime-precisao",
    "D12-datetime-timezone",
    "D13-cpf-variados",
    "D14-uuid-variados",
    "D15-base64-variados"
  ],
  "formats": ["csv", "jsonl", "json", "tcf"],
  "compressors": {
    "gzip":   {"level": 9,  "lib": "gzip (stdlib)",     "classes": ["web/http", "file/archive", "parquet", "general"]},
    "brotli": {"level": 11, "lib": "brotli 1.2.0",       "classes": ["web/http", "parquet"]},
    "zstd":   {"level": 22, "lib": "zstandard 0.25.0",   "classes": ["web/http", "file/archive", "parquet", "general"]},
    "lzma":   {"preset": 9, "lib": "lzma (stdlib)",      "classes": ["file/archive"]},
    "bz2":    {"level": 9,  "lib": "bz2 (stdlib)",       "classes": ["file/archive"]}
  },
  "reps_serialize": 20,
  "reps_compress": 30
}
