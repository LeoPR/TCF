.pytest_cache/
htmlcov/
.coverage

# Output artifacts (generated, not source)
output/

# Scratch / profiling (regenerable; conclusoes consolidadas em docs/theory/)
tmp/

# Cython acelerador compilado (gerado; fonte versionada e' o .pyx)
src/tcf/_core/*.c
src/tcf/_core/*.pyd
src/tcf/_core/*.so
src/tcf/_core/*.html

# Experiment results (large, regenerable)
# EXCECAO (T-QA-8 F1-3, 2026-07-10): evidencia-0.8/ e' MATERIAL COMPROBATORIO
# versionado (outputs visiveis pra auditoria — regra do material). O resto de
# results/ segue ignorado ('/*' + negacao porque dir excluido nao re-inclui filho).
experiments/results/*
!experiments/results/evidencia-0.8/
experiments/scratch/
experiments/data/
experiments/images/
experiments/models_local.json
experiments/eval_plan.json

# OS
Thumbs.db
.DS_Store
output*
# EXCECAO (2026-07-13, convencao de labs): pastas outputs/ dos labs DIRTY (novos) sao
# EVIDENCIA versionada. Escopo so' em dirty/ p/ nao expor outputs regeneraveis de labs
# antigos (clean/EXP-*, dirty/old/, baseline) que precedem a convencao.
!experiments/lab/dirty/**/outputs/
!experiments/lab/dirty/**/outputs/**
# re-ignora os PRE-convencao (regeneraveis, ficam como estavam):
experiments/lab/dirty/old/**/outputs/
experiments/lab/dirty/2026-05-27-baseline-consolidado/outputs/
restored*/
*.tcf
# EXCECAO (2026-07-13, convencao de labs): wire TCF de lab dirty (inputs/outputs) com extensao real
!experiments/lab/dirty/**/inputs/**/*.tcf
!experiments/lab/dirty/**/outputs/**/*.tcf

# Archive (legacy materials kept locally for history, not for public repo)
archive/legacy_results/
archive/old_tokenizer/
archive/rascunhos/
archive/tickets_v01/
archive/v01/src/
archive/v01/tests/
# Note: archive/v01/experiments/ and archive/misc/ are tracked (referenced by docs)

# === Datasets storage (Phase 1+) ===
# Config local with user-specific paths
config/storage.json
config/*.local.json
config/.env
config/.env.*

# Fallback local storage (data-local/) — only README and .gitkeep are tracked
data-local/**
!data-local/.gitkeep
!data-local/README.md

# Raw downloaded datasets (live in data_root/external/, not in project)
# Belt-and-suspenders: if someone drops CSVs in datasets/canonical/, ignore
datasets/canonical/*/*.csv
datasets/canonical/*/*.tsv
datasets/canonical/*/*.db
datasets/canonical/*/*.parquet
datasets/canonical/*/*.jsonl

# SQLite hub and derivations (live in data_root/interim/ and processed/)
datasets/sqlite/
datasets/derivations/

# Whitelist small files we DO want to track
!datasets/canonical/*/metadata.json
!datasets/canonical/*/README.md
!datasets/canonical/*/schema.sql
!datasets/samples/**/*.csv
!datasets/samples/**/*.md
!datasets/samples/**/.gitkeep
!datasets/quality-reports/*.md
!datasets/questions/*.json

pergunta.md

# Dev-efemero: scripts de orquestracao da ferramenta Workflow (produto durável
# vive nos .md/edicoes; git preserva historico). Politica: API estavel, dev efemero.
experiments/lab/dirty/notas/_wf_*.js

# Copias locais do legado #TCF.6/.7 pra comparativo (ADR-0032; git-as-compat)
legacy-snapshots/
